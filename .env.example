# Copy to .env next to the compose file you run (deploy/.env) and fill in.

# Postgres (compose wires these into the backend containers automatically)
POSTGRES_USER=lazarus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lazarus

# Honest bot identity sent to every target site. Put a real contact URL/email in it.
LAZARUS_USER_AGENT=LazarusBot/0.1 (+https://your-domain.example/about; contact@you.example)

# dev | prod
LAZARUS_ENVIRONMENT=dev

# Host ports for the dev stack. The app entry is Caddy on WEB_PORT (:8080).
# Override any that clash with something else already running on your machine.
WEB_PORT=8080
API_PORT=8000
FRONTEND_PORT=3000

# Runtime LLM (Phase 2). Both free tiers; sign up at console.groq.com and aistudio.google.com.
# Provider: groq (default) or gemini. The other is used as automatic fallback if configured.
LAZARUS_LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# Prod only: the public domain Caddy should obtain a Let's Encrypt cert for.
# Free options: yourname.duckdns.org, or <anything>.<VPS-IP-with-dashes>.nip.io
LAZARUS_DOMAIN=

# --- Phase 3: live API fabric / abuse protection ---
# Hosts that must never be scrape targets (SSRF protection beyond the built-in
# private-IP blocks). Put your VPS hostname AND its public IP here, comma-separated.
LAZARUS_DENY_HOSTS=

# Job-creation rate limits (fixed 1-hour windows, enforced in Redis).
LAZARUS_JOBS_PER_HOUR_PER_IP=3
LAZARUS_JOBS_PER_HOUR_GLOBAL=30

# At most this many live public APIs; beyond it the least recently used is evicted.
LAZARUS_MAX_ACTIVE_EXTRACTORS=20
