# Copy to .env next to the compose file you run (deploy/.env) and fill in.

# Postgres (compose wires these into the backend containers automatically)
POSTGRES_USER=lazarus
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lazarus

# Honest bot identity sent to every target site. Put a real contact URL/email in it.
LAZARUS_USER_AGENT=LazarusBot/0.1 (+https://your-domain.example/about; contact@you.example)

# dev | prod
LAZARUS_ENVIRONMENT=dev

# Runtime LLM (Phase 2). Both free tiers; sign up at console.groq.com and aistudio.google.com.
# Provider: groq (default) or gemini. The other is used as automatic fallback if configured.
LAZARUS_LLM_PROVIDER=groq
GROQ_API_KEY=
GEMINI_API_KEY=

# Prod only: the public domain Caddy should obtain a Let's Encrypt cert for.
# Free options: yourname.duckdns.org, or <anything>.<VPS-IP-with-dashes>.nip.io
LAZARUS_DOMAIN=
